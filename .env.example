# --- databricks-job-runner (required) ---
# DATABRICKS_PROFILE=azure-databricks-samples
DATABRICKS_COMPUTE_MODE=serverless
DATABRICKS_SERVERLESS_ENV_VERSION=3
DATABRICKS_WORKSPACE_DIR=/Users/<your-email>/graph_feature_forge
DATABRICKS_VOLUME_PATH=/Volumes/graph_feature_forge/enrichment/source-data

# --- graph_feature_forge pipeline config ---

# Workshop Delta tables (source data from Lab 4 export)
SOURCE_CATALOG=neo4j_augmentation_demo
SOURCE_SCHEMA=raw_data

# graph_feature_forge catalog (enrichment artifacts)
CATALOG_NAME=graph_feature_forge
SCHEMA_NAME=enrichment
VOLUME_NAME=source-data

# Model endpoints
LLM_ENDPOINT=databricks-claude-sonnet-4-6
EMBEDDING_ENDPOINT=databricks-gte-large-en

# SQL warehouse ID (required when no Spark session is available)
# WAREHOUSE_ID=

# ML training configuration (Phase 2.5 — see docs/sklearn.md)
# TEST_SIZE: internal train/test split ratio (e.g. 0.2 for 80/20).
# When set, skips external holdout and uses all labeled rows.
# TEST_SIZE=0.2
# PCA_COMPONENTS: reduce FastRP embedding dimensions via PCA (e.g. 5).
# Only affects fastrp_* columns; tabular features pass through.
# PCA_COMPONENTS=5

# Neo4j connection (required for extraction and write-back)
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Data generation (HTML + embeddings) ---
# LLM_ENDPOINT and EMBEDDING_ENDPOINT above are shared with the generator.
# Generator-specific settings use the GEN_ prefix:
# GEN_MAX_WORKERS=8                  # Thread pool size for parallel LLM calls
# GEN_NUM_CUSTOMER_PROFILES=8
# GEN_NUM_COMPANY_ANALYSES=12
# GEN_NUM_SECTOR_ANALYSES=7
# GEN_NUM_INVESTMENT_GUIDES=7
# GEN_NUM_BANK_PROFILES=4
# GEN_NUM_REGULATORY_DOCS=3
# GEN_CHUNK_SIZE=4000
# GEN_CHUNK_OVERLAP=200
# GEN_DRY_RUN=false
# GEN_SEED=42

# Databricks secret scope (protects credentials in job parameters)
# When set, Neo4j credentials are fetched from this scope at runtime
# instead of being passed as plaintext job parameters.
# Run ./create_secrets.sh to provision the scope from .env values.
DATABRICKS_SECRET_SCOPE=graph_feature_forge

# Databricks authentication (for local development)
# Uses ~/.databrickscfg profile if DATABRICKS_PROFILE is set above,
# otherwise set these explicitly:
# DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
# DATABRICKS_TOKEN=