# SQL warehouse ID (required for local SDK-based SQL execution)
# WAREHOUSE_ID=

# Databricks authentication (for local development)
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=
